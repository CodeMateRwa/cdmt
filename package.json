{
  "name": "cdmt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --host",
    "dev:backend": "tsx watch server/index.ts",
    "build": "tsc -b && vite build && npm run build:backend",
    "build:backend": "tsc -p server/tsconfig.json",
    "start": "tsx server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview --host",
    "db:push": "npx prisma db push --schema=server/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=server/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=server/prisma/schema.prisma"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^5.8.0",
    "autoprefixer": "^10.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^3.4.19",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/express": "^4.17.21",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
