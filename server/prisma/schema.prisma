generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  service   String
  budget    String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
}

model TeamMember {
  id       Int     @id @default(autoincrement())
  initial  String
  name     String
  role     String
  dept     String
  color    String
  skills   String[]
  bio      String
  quote    String
  linkedin String?
  twitter  String?
  photoKeywords String
  photoSig      Int
  order    Int     @default(0)
}

model WorkProject {
  id       Int     @id @default(autoincrement())
  title    String
  category String
  tags     String[]
  year     String
  desc     String
  color    String
  size     String
  challenge String
  outcome  String
  link     String?
  photoKeywords String
  photoSig      Int
  order    Int     @default(0)
}

model ServiceItem {
  id           Int      @id @default(autoincrement())
  num          String
  title        String
  desc         String
  icon         String
  capabilities String[]
  photoKeywords String
  photoSig      Int
  order        Int      @default(0)
}

// Single-row config tables (upserted by key)
model SiteConfig {
  key   String @id
  value Json
}
